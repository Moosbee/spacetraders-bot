  "query": "\n                SELECT\n                  id,\n                  waypoint_from as \"from\",\n                  waypoint_to as \"to\",\n                  created_at,\n                  updated_at\n                FROM jump_gate_connections\n                WHERE waypoint_from = $1\n                ORDER BY updated_at DESC, id DESC\n                LIMIT $2 OFFSET $3\n              ",
