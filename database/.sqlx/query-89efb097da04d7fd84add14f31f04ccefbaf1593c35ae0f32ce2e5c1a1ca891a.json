{
  "db_name": "PostgreSQL",
  "query": "\n                        SELECT \n                          id,\n                          symbol,\n                          account_id,\n                          headquarters,\n                          credits,\n                          starting_faction,\n                          ship_count,\n                          created_at\n                        FROM agent\n                        WHERE symbol = $1\n                        ORDER BY symbol ASC, created_at DESC\n                        LIMIT $2 OFFSET $3\n                    ",
